# Prisma API — imagem de runtime (contexto de build = raiz do repo)
FROM python:3.12-slim

WORKDIR /app
# torch CPU-only primeiro (evita ~6GB de libs CUDA inúteis nesta VPS sem GPU)
RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch
# Decidi instalar a partir do requirements.txt (não mais uma lista hardcoded
# aqui) porque notei, no deploy de 2026-07-14, que a lista fixa tinha
# ficado defasada (faltava feedparser) e derrubou a API em produção — pip
# -r é a mesma fonte de verdade que o resto do time usa localmente.
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# núcleo (finrag vendorizado vem junto de services/prisma-api) + dados do POC
COPY services/prisma-api /app/services/prisma-api
COPY data /app/data

WORKDIR /app/services/prisma-api
EXPOSE 8000
# Sem Ollama na VPS: embeddings caem para sentence-transformers (baixado no 1º boot).
CMD ["python", "-m", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]
